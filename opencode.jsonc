{
  "$schema": "https://opencode.ai/config.json",

  // Override with OPENCODE_MODEL in .env if desired.
  "model": "nvidia/deepseek-ai/deepseek-v4-pro",

  "provider": {
    "nvidia": {
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1"
      },
      "models": {
        "deepseek-ai/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        }
      }
    }
  },

  "instructions": [
    "AGENTS.md",
    "directions/*.md"
  ],

  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "edit": "allow",
    "write": "allow",
    "bash": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  },

  "watcher": {
    "ignore": [
      "runs/**",
      "state/**",
      "target/repo/.git/**",
      "target/repo/.venv/**",
      "target/repo/node_modules/**",
      "target/repo/dist/**",
      "target/repo/build/**"
    ]
  }
}
