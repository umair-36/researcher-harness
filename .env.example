# OpenCode model. Default target is NVIDIA NIM DeepSeek V4 Pro.
OPENCODE_MODEL=nvidia/deepseek-ai/deepseek-v4-pro

# NVIDIA Build / NIM key.
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Set to 1 for unattended runs. This lets OpenCode run approved tools without interactive prompts.
# Use only in a disposable repo/container.
OPENCODE_AUTO_APPROVE=1

# Keep OpenCode session continuity in addition to file-based history.
# The harness already passes state/history.jsonl into every prompt, so 0 is the simpler default.
OPENCODE_CONTINUE=0
